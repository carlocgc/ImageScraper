root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.{bat,cmd,ps1}]
end_of_line = crlf

[*.{c,cpp,filters,gitignore,h,hpp,html,inl,json,md,props,runsettings,sln,targets,txt,vcxproj,yaml,yml}]
end_of_line = lf

[.editorconfig]
end_of_line = lf

[.gitattributes]
end_of_line = lf

[*.md]
trim_trailing_whitespace = false
